{
  "description": "CC Nav hooks: ワーカー環境検出、セッション開始時のコンテキスト注入、AskUserQuestionブロック",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/session-start.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": {
          "toolName": "AskUserQuestion"
        },
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/block-ask-in-worker.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
